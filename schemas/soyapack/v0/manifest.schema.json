{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://specs.soyaos.ai/schemas/soyapack/v0/manifest.schema.json",
  "title": "SoyaPack Manifest v0",
  "description": "Canonical schema for soyapack.yaml. Implementations validate after YAML→JSON conversion. Unknown top-level fields not prefixed with 'x-' are rejected.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "spec_version",
    "kind",
    "name",
    "version",
    "description",
    "authors",
    "license",
    "runtime",
    "determinism"
  ],
  "properties": {
    "spec_version": { "const": "soyapack.v0" },
    "kind": { "enum": ["Skill", "Agent", "Memory"] },
    "name": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9-]{0,46}[a-z0-9]$"
    },
    "version": {
      "type": "string",
      "pattern": "^(0|[1-9]\\d*)\\.(0|[1-9]\\d*)\\.(0|[1-9]\\d*)(?:-((?:0|[1-9]\\d*|\\d*[a-zA-Z-][0-9a-zA-Z-]*)(?:\\.(?:0|[1-9]\\d*|\\d*[a-zA-Z-][0-9a-zA-Z-]*))*))?(?:\\+([0-9a-zA-Z-]+(?:\\.[0-9a-zA-Z-]+)*))?$"
    },
    "description": { "type": "string", "maxLength": 280 },
    "authors": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name"],
        "properties": {
          "name": { "type": "string", "minLength": 1 },
          "email": { "type": "string", "format": "email" }
        }
      }
    },
    "license": { "type": "string", "minLength": 1 },
    "homepage": { "type": "string", "format": "uri" },
    "runtime": {
      "type": "object",
      "additionalProperties": false,
      "required": ["compat"],
      "properties": {
        "compat": { "type": "string", "minLength": 1 }
      }
    },
    "determinism": { "enum": ["pure", "read-only", "stateful"] },
    "affinity": { "enum": ["planet", "moon", "comet", "any"] },
    "deps": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "lockfile": { "type": "string", "pattern": "^[a-f0-9]{64}$" }
      }
    },
    "sbom": { "type": "string", "default": "sbom.spdx.json" },
    "signatures": {
      "type": "array",
      "items": { "type": "object" }
    },
    "entry": { "type": "string" },
    "expose": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "openai_compat": { "enum": ["chat", "responses", "both"] },
        "virtual_model_id": { "type": "string", "pattern": "^soya:[a-z][a-z0-9-]{0,46}[a-z0-9]$" }
      }
    },
    "inputs": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "type"],
        "properties": {
          "name": { "type": "string" },
          "type": { "type": "string" },
          "optional": { "type": "boolean" },
          "items": { "type": "object" }
        }
      }
    },
    "outputs": {
      "type": "array",
      "items": { "type": "object" }
    },
    "prompt": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "scaffold": { "type": "string" },
        "tools": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "artifacts": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["kind", "schema"],
        "properties": {
          "kind": { "enum": ["html", "pdf", "long_image", "markdown", "xlsx", "mp4"] },
          "schema": { "type": "string" }
        }
      }
    },
    "schedules": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "cron": { "type": "string" },
          "once": { "type": "string", "format": "date-time" },
          "tz": { "type": "string" },
          "payload": { "type": "object" },
          "idempotency_key": { "type": "string" },
          "missed_fire": { "enum": ["skip", "once", "backfill"] }
        },
        "anyOf": [
          { "required": ["cron"] },
          { "required": ["once"] }
        ]
      }
    },
    "channels": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["kind"],
        "properties": {
          "kind": { "enum": ["dingtalk", "feishu", "wework", "wechat-mp", "wechat-cs", "webhook"] },
          "binding_template": { "type": "string" }
        }
      }
    },
    "actions": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "on", "handler"],
        "properties": {
          "id": { "type": "string" },
          "on": { "enum": ["per_row", "button", "api"] },
          "handler": { "type": "string" },
          "timeout": { "type": "string" },
          "artifacts": { "type": "array", "items": { "type": "string" } }
        }
      }
    },
    "state": {
      "type": "object",
      "additionalProperties": false,
      "required": ["scope", "store"],
      "properties": {
        "scope": { "enum": ["agent", "user", "tenant"] },
        "store": { "enum": ["memory", "kv", "db"] }
      }
    },
    "sandbox": {
      "type": "object",
      "additionalProperties": false,
      "required": ["isolation", "image"],
      "properties": {
        "isolation": { "enum": ["process", "container", "microvm"] },
        "image": { "type": "string" },
        "budget_seconds_max": { "type": "integer", "minimum": 1 },
        "cold_start_target_ms": { "type": "integer", "minimum": 0 },
        "capabilities": { "type": "object" }
      }
    },
    "uses": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[a-z][a-z0-9-]+@.+$"
      }
    },
    "mount": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "partition": { "type": "string" },
        "access": { "enum": ["ro", "rw"] },
        "format": { "enum": ["embeddings", "kv", "json-lines"] },
        "embedding": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "model": { "type": "string" },
            "fingerprint": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
            "dim": { "type": "integer", "minimum": 1 }
          }
        }
      }
    },
    "contents": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["path", "sha256", "size"],
        "properties": {
          "path": { "type": "string" },
          "sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
          "size": { "type": "integer", "minimum": 0 }
        }
      }
    }
  },
  "allOf": [
    {
      "if": { "properties": { "kind": { "const": "Agent" } } },
      "then": {
        "required": ["entry", "expose"]
      }
    },
    {
      "if": { "properties": { "kind": { "const": "Skill" } } },
      "then": {
        "required": ["entry"]
      }
    },
    {
      "if": { "properties": { "kind": { "const": "Memory" } } },
      "then": {
        "required": ["mount", "contents"]
      }
    }
  ],
  "patternProperties": {
    "^x-": {}
  }
}
